  "reasoning_field_patterns": [
    [
      "artifact_unit",
      "^\\s*-\\s+artifact_unit:",
      1.0
    ],
    [
      "method_family",
      "^\\s*-\\s+method_family:",
      1.0
    ],
    [
      "reasoning_operator",
      "^\\s*-\\s+reasoning_operator:",
      1.0
    ],
    [
      "alternatives_compared",
      "^\\s*-\\s+(?:alternatives_compared|对比过的方案\\s+\\(alternatives_compared\\)):",
      1.0
    ],
    [
      "tradeoff_or_tension",
      "^\\s*-\\s+(?:tradeoff_or_tension|权衡\\s*/\\s*张力\\s+\\(tradeoff_or_tension\\)):",
      1.0
    ],
    [
      "decision_effect",
      "^\\s*-\\s+(?:decision_effect|决策效果\\s+\\(decision_effect\\)):",
      1.0
    ],
    [
      "evidence_classification",
      "^\\s*-\\s+evidence_classification:",
      1.0
    ],
    [
      "evidence_state",
      "^\\s*-\\s+evidence_state:",
      1.0
    ],
    [
      "downstream_handoff",
      "^\\s*-\\s+(?:downstream_handoff|向下游的交接要求\\s+\\(downstream_handoff\\)):",
