beforeAll(async () => {
  runtime = await startBackendRuntime();
  await runtime.initializeDatabase();
});

afterAll(async () => {
  await runtime.close();
});

let scenarioInitialized = true;

beforeEach(async () => {
  if (scenarioInitialized) {
    scenarioInitialized = false;
    return;
  }
  await runtime.restoreRuntimeOnly();
});

